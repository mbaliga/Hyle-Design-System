{
  "font": {
    "family": {
      "sans": { "$value": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace", "$type": "fontFamily" }
    },
    "weight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" }
    },
    "size": {
      "xs":   { "$value": "12", "$type": "dimension" },
      "sm":   { "$value": "14", "$type": "dimension" },
      "md":   { "$value": "16", "$type": "dimension" },
      "lg":   { "$value": "18", "$type": "dimension" },
      "xl":   { "$value": "20", "$type": "dimension" },
      "2xl":  { "$value": "24", "$type": "dimension" },
      "3xl":  { "$value": "30", "$type": "dimension" },
      "4xl":  { "$value": "36", "$type": "dimension" }
    },
    "lineHeight": {
      "tight":   { "$value": "1.2", "$type": "number" },
      "normal":  { "$value": "1.5", "$type": "number" },
      "relaxed": { "$value": "1.7", "$type": "number" }
    }
  }
}

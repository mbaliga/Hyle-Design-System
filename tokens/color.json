{
  "color": {
    "palette": {
      "field": {
        "void":   { "$value": "#000000", "$type": "color", "$description": "Pure black — the art/Field canvas only (see ethos: SEM is colourless)." },
        "near":   { "$value": "#0a0809", "$type": "color", "$description": "The inky base behind glass." },
        "raised": { "$value": "#121212", "$type": "color", "$description": "UI surfaces sit at #121212-class, never pure black, to reduce halation (WCAG/ethos §5e)." },
        "deep":   { "$value": "#050009", "$type": "color", "$description": "Fallback / deepest backdrop." }
      },
      "ink": {
        "pure":  { "$value": "#ece8e4", "$type": "color", "$description": "Warm off-white at full opacity." },
        "full":  { "$value": "rgba(236, 232, 228, 0.92)", "$type": "color", "$description": "Primary text." },
        "dim":   { "$value": "rgba(236, 232, 228, 0.42)", "$type": "color", "$description": "Secondary text." },
        "faint": { "$value": "rgba(236, 232, 228, 0.18)", "$type": "color", "$description": "Micro-labels, hairline text." }
      },
      "accent": {
        "violet":       { "$value": "#8e7bff", "$type": "color", "$description": "The single north-star accent. Light is scarce; spend it here." },
        "violet-bright":{ "$value": "#a593ff", "$type": "color" },
        "violet-deep":  { "$value": "#7867e6", "$type": "color" }
      },
      "provenance": {
        "native": { "$value": "#6be6a4", "$type": "color", "$description": "Radium-green = on-device / home. MUST pair with a non-colour channel (WCAG 1.4.1)." },
        "cloud":  { "$value": "#4fd6e6", "$type": "color", "$description": "Alien-cyan = cloud / foreign. MUST pair with a non-colour channel (WCAG 1.4.1)." }
      },
      "hairline": {
        "default": { "$value": "rgba(255, 255, 255, 0.08)", "$type": "color" },
        "strong":  { "$value": "rgba(255, 255, 255, 0.14)", "$type": "color" }
      },
      "glass": {
        "pane": { "$value": "rgba(10, 8, 9, 0.52)", "$type": "color", "$description": "Frosted-glass panel fill; pair with backdrop-blur." }
      },
      "signal": {
        "danger":  { "$value": "#e5564b", "$type": "color" },
        "warning": { "$value": "#e0941a", "$type": "color" },
        "success": { "$value": "#5bbf7a", "$type": "color" }
      },
      "material": {
        "stone": { "$value": "#9b958c", "$type": "color", "$description": "Form-World stone/smog/light, kept separate. Surface albedo of the forms behind the pane." },
        "smog":  { "$value": "#cc1a0a", "$type": "color", "$description": "Atmosphere / fog colour." },
        "light": { "$value": "#ffd2b0", "$type": "color", "$description": "Key light, specular, sun disc." }
      }
    },

    "text": {
      "primary":   { "$value": "{color.palette.ink.full}", "$type": "color" },
      "secondary": { "$value": "{color.palette.ink.dim}", "$type": "color" },
      "faint":     { "$value": "{color.palette.ink.faint}", "$type": "color" },
      "inverse":   { "$value": "{color.palette.field.near}", "$type": "color", "$description": "Ink-on-light, e.g. a pressed chip." },
      "accent":    { "$value": "{color.palette.accent.violet}", "$type": "color" }
    },
    "background": {
      "field":   { "$value": "{color.palette.field.void}", "$type": "color" },
      "surface": { "$value": "{color.palette.field.raised}", "$type": "color" },
      "glass":   { "$value": "{color.palette.glass.pane}", "$type": "color" },
      "inverse": { "$value": "{color.palette.ink.pure}", "$type": "color" }
    },
    "border": {
      "hairline": { "$value": "{color.palette.hairline.default}", "$type": "color" },
      "strong":   { "$value": "{color.palette.hairline.strong}", "$type": "color" },
      "focus":    { "$value": "{color.palette.accent.violet}", "$type": "color" }
    },
    "action": {
      "primary":        { "$value": "{color.palette.accent.violet}", "$type": "color" },
      "primary-hover":  { "$value": "{color.palette.accent.violet-bright}", "$type": "color" },
      "primary-active": { "$value": "{color.palette.accent.violet-deep}", "$type": "color" },
      "on-primary":     { "$value": "{color.palette.field.near}", "$type": "color" }
    },
    "provenance": {
      "native": { "$value": "{color.palette.provenance.native}", "$type": "color" },
      "cloud":  { "$value": "{color.palette.provenance.cloud}", "$type": "color" }
    },
    "feedback": {
      "danger":  { "$value": "{color.palette.signal.danger}", "$type": "color" },
      "warning": { "$value": "{color.palette.signal.warning}", "$type": "color" },
      "success": { "$value": "{color.palette.signal.success}", "$type": "color" }
    }
  }
}
